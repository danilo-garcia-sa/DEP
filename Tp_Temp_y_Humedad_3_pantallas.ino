const int epd_bitmap_allArray_LEN = 1;
const unsigned char* epd_bitmap_allArray[1] = {
	epd_bitmap_agua_64
};

const int pinBoton = 0;
int estadoAnterior = HIGH;
int pantallaActiva = 1;

DHT dht(19, DHT22);

int tempCelsius;
int humedadRelativa;
int presionAtmos;

void setup() {
  Serial.begin(115200);
  display.setTextColor(WHITE, BLACK);
  display.setTextSize(2);
  pinMode(pinBoton, INPUT);
  delay(500);
  
  if(!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) {
    Serial.println(F("SSD1306 allocation failed"));
    while (1); 
  }
  
  Serial.println(F("DHTxx test!"));
  dht.begin();
  
  if (!bmp.begin(BMP280_ADDRESS_ALT)) {
    Serial.println("Could not find a valid BMP280 sensor, check wiring!");
    while (1);
  }
}
  
void loop() {    
    presionAtmos = bmp.readPressure(); 
    humedadRelativa = (int) dht.readHumidity();
    tempCelsius = (int) dht.readTemperature();
    
    int estadoPulsador = digitalRead(pinBoton);
    if (estadoPulsador == LOW && estadoAnterior == HIGH)
    {
      if (pantallaActiva == 1){
        pantallaActiva = 2;
      } else if (pantallaActiva == 2) {
        pantallaActiva = 3;
      }
      else{
        pantallaActiva = 1;
      }
    }
    estadoAnterior = estadoPulsador;
    
    if (pantallaActiva == 1 ){
        displayTemperatura();
    }
    else if (pantallaActiva == 2) {
        displayHumedad();
    }
    else{
        displayPresion();
    }
    
    Serial.print("Temperature = ");
    Serial.println(" C");    
    Serial.println();
    delay(50);

    if (isnan(humedadRelativa) || isnan(tempCelsius) ){
      Serial.println(F("Failed to read from DHT sensor!"));
      return;
    }
}

void displayTemperatura() {
  display.clearDisplay();
  display.drawBitmap(0,0, bmp_icons8_term_metro_64,64,64, WHITE);
  display.setCursor(64,24);
  display.print(tempCelsius);
  display.write(0xF7);
  display.print("C");
  display.display();
}

void displayHumedad(){
  display.clearDisplay();
  display.drawBitmap(0,0, epd_bitmap_agua_64,64,64, WHITE);
  display.setCursor(60,24);
  display.print(humedadRelativa);
  display.print("%");
  display.display();
}

void displayPresion(){
  display.clearDisplay();
  display.drawBitmap(0,0, bmp_icons_presion_atmos,64,64, WHITE);
  display.setCursor(70,24);
  display.print(presionAtmos / 100);
  display.setCursor(70,48);
  display.print("HPa");
  display.display();
}